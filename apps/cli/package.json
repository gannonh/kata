{
  "name": "@kata-sh/cli",
  "version": "0.16.0-alpha.0",
  "description": "Kata CLI runtime and backend contract bridge",
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gannonh/kata.git",
    "directory": "apps/cli"
  },
  "type": "module",
  "bin": {
    "kata": "dist/loader.js",
    "kata-cli": "dist/loader.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "skills",
    "package.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "build": "tsc && node scripts/bundle-skills.mjs",
    "test": "pnpm exec vitest run",
    "test:vitest": "pnpm exec vitest run",
    "test:coverage": "pnpm exec vitest run --coverage",
    "dev": "tsc --watch",
    "prepublishOnly": "pnpm run build",
    "lint": "eslint src/ --max-warnings=500",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
