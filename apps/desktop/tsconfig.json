{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client", "electron", "react", "react-dom"],
    "paths": {
      "@/*": ["./src/renderer/*"],
      "@shared/*": ["./src/shared/*"],
      "@kata/core": ["../../packages/core/src/index.ts"],
      "@kata/core/*": ["../../packages/core/src/*"],
      "@kata/shared": ["../../packages/shared/src/index.ts"],
      "@kata/shared/*": ["../../packages/shared/src/*"],
      "@kata/ui": ["../../packages/ui/src/index.ts"],
      "@kata/ui/*": ["../../packages/ui/src/*"],
      "@kata/mermaid": ["../../packages/mermaid/src/index.ts"],
      "@kata/mermaid/*": ["../../packages/mermaid/src/*"]
    }
  },
  "include": ["src/**/*", "vite.config.ts"],
  "exclude": ["dist", "node_modules"]
}
