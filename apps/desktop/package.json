{
  "name": "@kata/desktop",
  "version": "0.2.9",
  "description": "Kata Desktop — native desktop app for the Kata coding agent",
  "private": true,
  "type": "module",
  "main": "dist/main.cjs",
  "author": {
    "name": "Kata Contributors",
    "email": "hello@kata.sh"
  },
  "homepage": "https://github.com/gannonh/kata",
  "license": "MIT",
  "scripts": {
    "build:main": "esbuild src/main/index.ts --bundle --platform=node --format=cjs --outfile=dist/main.cjs --external:electron",
    "build:preload": "esbuild src/preload/index.ts --bundle --platform=node --format=cjs --outfile=dist/preload.cjs --external:electron",
    "build:renderer": "vite build",
    "build": "pnpm run build:main && pnpm run build:preload && pnpm run build:renderer",
    "bundle:cli": "bash ./scripts/bundle-cli.sh",
    "desktop:build": "pnpm run build",
    "prepare:builder-app": "bash ./scripts/prepare-builder-app.sh",
    "desktop:dist:mac": "bash ./scripts/package-mac.sh",
    "dist:mac": "pnpm run desktop:dist:mac",
    "dev:main": "esbuild src/main/index.ts --bundle --platform=node --format=cjs --outfile=dist/main.cjs --external:electron --watch --sourcemap",
    "dev:preload": "esbuild src/preload/index.ts --bundle --platform=node --format=cjs --outfile=dist/preload.cjs --external:electron --watch --sourcemap",
    "dev:renderer": "vite dev --host 127.0.0.1 --port 5174 --strictPort",
    "dev:electron": "wait-on tcp:5174 file:dist/main.cjs file:dist/preload.cjs && VITE_DEV_SERVER_URL=http://127.0.0.1:5174 electron .",
    "desktop:dev": "concurrently -k -n MAIN,PRELOAD,RENDERER,ELECTRON -c green,cyan,magenta,yellow \"pnpm run dev:main\" \"pnpm run dev:preload\" \"pnpm run dev:renderer\" \"pnpm run dev:electron\"",
    "typecheck": "tsc --noEmit",
    "test": "npx vitest run --coverage",
    "test:watch": "npx vitest",
    "test:e2e": "npx playwright test",
    "test:e2e:symphony-end-to-end": "npx playwright test e2e/tests/symphony-end-to-end.e2e.ts",
    "test:e2e:headed": "npx playwright test --headed",
    "qa:m006:soak": "pnpm exec tsx scripts/qa/m006-soak-run.ts",
    "qa:m006:release-gate": "pnpm exec tsx scripts/qa/m006-release-gate.ts"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@kata-sh/cli": "workspace:*",
    "@kata/core": "workspace:*",
    "@kata/mermaid": "workspace:*",
    "@kata/shared": "workspace:*",
    "@kata/ui": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "electron-log": "^5.4.4",
    "esbuild": "^0.28.1",
    "jotai": "^2.20.0",
    "jsdom": "^29.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-resizable-panels": "^4.11.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  }
}
