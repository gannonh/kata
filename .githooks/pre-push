#!/bin/bash
# Pre-push hook: run the same validation surface as CI for changed packages.
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"

# Load full PATH for GUI apps (Fork, Tower, etc.) that don't inherit shell config.
eval "$(/opt/homebrew/bin/brew shellenv 2>/dev/null)" || true
. "$HOME/.cargo/env" 2>/dev/null || true
if [ -d "$HOME/.bun/bin" ]; then
  export PATH="$HOME/.bun/bin:$PATH"
fi

# Prefer the exact Node version from .node-version so local validation mirrors
# CI. Fall back to the newest installed major if the exact patch isn't present.
desired_node="$(tr -d '[:space:]' < "$repo_root/.node-version" 2>/dev/null || true)"
if [ -n "$desired_node" ] && [ -d "$HOME/.nvm/versions/node" ]; then
  exact_node="$HOME/.nvm/versions/node/v$desired_node"
  if [ -d "$exact_node" ]; then
    export PATH="$exact_node/bin:$PATH"
  else
    node_major="${desired_node%%.*}"
    fallback_node=$(ls -d "$HOME/.nvm/versions/node/v${node_major}"* 2>/dev/null | sort -V | tail -1)
    if [ -n "${fallback_node:-}" ]; then
      export PATH="$fallback_node/bin:$PATH"
    fi
  fi
fi

echo "[pre-push] node: $(node --version)"

echo "[pre-push] phase: rebuild-native-addons"
(pnpm --dir apps/context rebuild better-sqlite3 tree-sitter 2>/dev/null) || true

echo "[pre-push] phase: turbo-active-packages"
if ! pnpm exec turbo run lint typecheck test \
  --filter=@kata/desktop \
  --filter=@kata-sh/cli \
  --filter=@kata/context \
  --filter=@kata-sh/orc \
  --filter=@kata/core \
  --filter=@kata/shared \
  --filter=@kata/ui \
  --filter=@kata/mermaid; then
  echo ""
  echo "Pre-push validation failed. Fix the issues above before pushing."
  exit 1
fi
