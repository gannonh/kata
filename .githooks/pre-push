#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if ! command -v bun >/dev/null 2>&1; then
  echo "pre-push: Bun is required but was not found in PATH." >&2
  echo "Install Bun, then run 'bun install' and try pushing again." >&2
  exit 1
fi

if [[ ! -d node_modules ]]; then
  echo "pre-push: dependencies are missing (node_modules not found)." >&2
  echo "Run 'bun install' before pushing." >&2
  exit 1
fi

echo "pre-push: running local validate gate..."
bun run validate:local
