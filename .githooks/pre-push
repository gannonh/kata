#!/bin/bash
# Pre-push hook: run the same validation surface as CI for changed packages.
set -euo pipefail

# Load full PATH for GUI apps (Fork, Tower, etc.) that don't inherit shell config.
eval "$(/opt/homebrew/bin/brew shellenv 2>/dev/null)" || true
. "$HOME/.cargo/env" 2>/dev/null || true

# Pin Node 22 (matches CI and .node-version). Native addons (better-sqlite3,
# tree-sitter) don't compile on Node 23, and Vitest runs under Node.
if [ -d "$HOME/.nvm/versions/node" ]; then
  NODE22=$(ls -d "$HOME/.nvm/versions/node/v22"* 2>/dev/null | sort -V | tail -1)
  if [ -n "$NODE22" ]; then
    export PATH="$NODE22/bin:$PATH"
  fi
fi

echo "[pre-push] node: $(node --version)"

echo "[pre-push] phase: rebuild-native-addons"
(pnpm --dir apps/context rebuild better-sqlite3 tree-sitter 2>/dev/null) || true

echo "[pre-push] phase: turbo-active-packages"
if ! pnpm exec turbo run lint typecheck test \
  --filter=@kata/desktop \
  --filter=@kata-sh/cli \
  --filter=@kata/context \
  --filter=@kata-sh/orc; then
  echo ""
  echo "Pre-push validation failed. Fix the issues above before pushing."
  exit 1
fi
