{
  "name": "kata",
  "version": "0.0.0",
  "description": "Kata monorepo",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "lint": "pnpm exec turbo run lint",
    "typecheck": "pnpm exec turbo run typecheck",
    "test": "pnpm exec turbo run test",
    "test:affected": "turbo run test --affected",
    "test:watch": "pnpm exec turbo watch test",
    "test:coverage": "bun run scripts/coverage-summary.ts",
    "test:coverage:summary": "bun run scripts/coverage-summary.ts",
    "test:e2e": "pnpm --dir apps/desktop run test:e2e",
    "test:e2e:headed": "pnpm --dir apps/desktop run test:e2e:headed",
    "build": "turbo run build",
    "validate": "pnpm exec turbo run lint typecheck test",
    "validate:affected": "pnpm exec turbo run lint typecheck test --affected",
    "verify:pnpm": "bash scripts/verify-pnpm-migration.sh",
    "githooks:install": "bash scripts/install-githooks.sh",
    "link": "bun link",
    "desktop:dev": "pnpm --dir apps/desktop run desktop:dev",
    "desktop:build": "pnpm --dir apps/desktop run desktop:build",
    "desktop:dist:mac": "pnpm --dir apps/desktop run desktop:dist:mac",
    "sync-secrets": "bash scripts/sync-secrets.sh",
    "fresh-start": "bun run scripts/fresh-start.ts",
    "fresh-start:token": "bun run scripts/fresh-start.ts --token-only",
    "print:system-prompt": "pnpm exec tsx packages/shared/src/prompts/print-system-prompt.ts",
    "marketing:dev": "vite dev --config apps/marketing/vite.config.ts",
    "marketing:build": "vite build --config apps/marketing/vite.config.ts",
    "marketing:preview": "vite preview --config apps/marketing/vite.config.ts",
    "docs:dev": "pnpm --dir apps/online-docs run docs:dev",
    "release": "bun run scripts/release.ts",
    "check-version": "bun run scripts/check-version.ts",
    "oss:sync": "bun run scripts/oss-sync.ts",
    "demo:setup": "bun run scripts/setup-demo.ts",
    "demo:reset": "bun run scripts/setup-demo.ts --reset",
    "demo:launch": "bash scripts/launch-demo.sh",
    "demo:repo": "bash scripts/create-demo-repo.sh"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1033.0",
    "@electron/packager": "^19.0.1",
    "@rollup/rollup-win32-arm64-msvc": "^4.60.2",
    "@sentry/vite-plugin": "^5.1.1",
    "@tailwindcss/vite": "^4.2.3",
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/linkify-it": "^5.0.0",
    "@types/node": "^25.0.8",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/semver": "^7.7.1",
    "@types/shell-quote": "^1.7.5",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^6.0.1",
    "agentation": "^3.0.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.5.10",
    "react-devtools-core": "^7.0.1",
    "tailwindcss": "^4.2.3",
    "tar": "^7.5.2",
    "turbo": "^2.8.17",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.119",
    "@anthropic-ai/sdk": "^0.91.0",
    "@hapi/boom": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.24.3",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/electron": "^7.7.0",
    "@sentry/react": "^10.50.0",
    "@shikijs/cli": "^4.0.2",
    "@slack/socket-mode": "^2.0.5",
    "@slack/web-api": "^7.15.1",
    "@tailwindcss/typography": "^0.5.19",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "croner": "^10.0.1",
    "date-fns": "^4.1.0",
    "gray-matter": "^4.0.3",
    "jotai": "^2.16.0",
    "js-yaml": "^4.1.1",
    "linkify-it": "^5.0.0",
    "lucide-react": "^1.9.0",
    "marked": "^18.0.2",
    "markitdown-js": "^0.0.14",
    "md-to-slack": "^1.1.7",
    "open": "^11.0.0",
    "pino": "^10.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.6.3",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "semver": "^7.7.3",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.0.0"
  },
  "trustedDependencies": [
    "tree-sitter-typescript",
    "tree-sitter-python"
  ]
}
