{
  "name": "kata",
  "version": "0.0.0",
  "description": "Kata monorepo",
  "type": "module",
  "private": true,
  "license": "MIT",
  "keywords": [
    "pi-package",
    "kata"
  ],
  "packageManager": "pnpm@10.6.2",
  "pi": {
    "extensions": [
      "apps/symphony/pi-extension/src/index.ts"
    ]
  },
  "scripts": {
    "lint": "pnpm exec turbo run lint",
    "typecheck": "pnpm exec turbo run typecheck",
    "test": "pnpm exec turbo run test",
    "test:affected": "turbo run test --affected",
    "test:watch": "pnpm exec turbo watch test",
    "test:coverage": "bun run scripts/coverage-summary.ts",
    "test:coverage:summary": "bun run scripts/coverage-summary.ts",
    "build": "turbo run build",
    "build:cli:pi": "pnpm --dir apps/cli run build && node apps/cli/dist/loader.js setup --pi",
    "build:cli:local": "pnpm --dir apps/cli run build && node apps/cli/dist/loader.js setup --local",
    "build:cli:global": "pnpm --dir apps/cli run build && node apps/cli/dist/loader.js setup --global",
    "validate": "pnpm exec turbo run lint typecheck test",
    "validate:affected": "pnpm exec turbo run lint typecheck test --affected",
    "verify:pnpm": "bash scripts/verify-pnpm-migration.sh",
    "githooks:install": "bash scripts/install-githooks.sh",
    "link": "bun link",
    "sync-secrets": "bash scripts/sync-secrets.sh",
    "print:system-prompt": "pnpm exec tsx packages/shared/src/prompts/print-system-prompt.ts"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/linkify-it": "^5.0.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/semver": "^7.7.1",
    "@types/shell-quote": "^1.7.5",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "tar": "^7.5.19",
    "turbo": "^2.10.1",
    "vite": "^8.1.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.131",
    "@anthropic-ai/sdk": "^0.94.0",
    "@hapi/boom": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.24.3",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@shikijs/cli": "^4.0.2",
    "@slack/socket-mode": "^2.0.7",
    "@slack/web-api": "^7.15.2",
    "@tailwindcss/typography": "^0.5.19",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "croner": "^10.0.1",
    "date-fns": "^4.1.0",
    "gray-matter": "^4.0.3",
    "jotai": "^2.20.0",
    "js-yaml": "^4.1.1",
    "linkify-it": "^5.0.0",
    "lucide-react": "^1.14.0",
    "marked": "^18.0.3",
    "markitdown-js": "^0.0.14",
    "md-to-slack": "^1.1.7",
    "open": "^11.0.0",
    "pino": "^10.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "semver": "^7.7.3",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.4.0",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
  }
}
