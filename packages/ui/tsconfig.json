{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@kata/core": ["../core/src/index.ts"],
      "@kata/core/*": ["../core/src/*"],
      "@kata/mermaid": ["../mermaid/src/index.ts"],
      "@kata/mermaid/*": ["../mermaid/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
