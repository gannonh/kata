# Symphony environment template
#
# Copy values from this file into your repo root `.env` or export them in your
# shell before running Symphony. Symphony automatically loads `<git-root>/.env`
# when started inside a git repository.

# GitHub tracker auth, required when tracker.kind: github.
# Use a classic PAT with scopes: repo, project, workflow, read:org, read:discussion.
GH_TOKEN=ghp_replace_me

# Linear tracker auth, required when tracker.kind: linear.
LINEAR_API_KEY=lin_api_replace_me

# Agent auth. Set the key for your chosen backend/provider, or authenticate your
# local agent harness separately when supported.
# ANTHROPIC_API_KEY=sk-ant-replace-me
# OPENAI_API_KEY=sk-replace-me

# Log level. Defaults to info.
SYMPHONY_LOG=info

# Optional Slack webhook URL for notifications.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
